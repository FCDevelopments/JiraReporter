# Copy this file to ".env" and fill in your values.
# Never commit .env to version control — it contains your API token.

JIRA_EMAIL=you@yourcompany.com
JIRA_API_TOKEN=your_api_token_here
JIRA_BASE_URL=https://yourcompany.atlassian.net/rest/api/3
JIRA_PROJECT_KEY=YOUR_PROJECT_KEY

# --- Optional: Snowflake export (export_for_snowflake.py) ---
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_ROLE=

# --- Email digest (jira_emailer.py) ---
EMAIL_TO=you@yourcompany.com
# EMAIL_CC=manager@yourcompany.com
